# Copy this file to .env and fill in values
# Windows PowerShell: Copy-Item .env.example .env

# REQUIRED: MongoDB connection string
# Atlas example:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<dbName>?retryWrites=true&w=majority
# Local MongoDB example:
# MONGODB_URI=mongodb://127.0.0.1:27017/itpm_project
MONGODB_URI=

# Optional but recommended
JWT_SECRET=change-me
CLIENT_ORIGIN=http://localhost:5173
PORT=5000

# Email (SMTP) - required for OTP emails and monthly report emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# Monthly reports (leader opt-in must also be enabled per club)
# When true, the server will check hourly and send the previous month's report on the 1st day of each month.
ENABLE_MONTH_END_REPORT_EMAILS=false
